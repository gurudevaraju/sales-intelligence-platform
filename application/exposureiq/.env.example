# Copy this file to .env and fill in your real values.
# .env is for LOCAL development only - on Elastic Beanstalk, set these as
# environment properties instead (eb setenv KEY=value, or the EB console
# under Configuration > Software > Environment properties). Never commit
# a real .env file.

# ---- Postgres / RDS (required) ----
# Format: postgresql://USERNAME:PASSWORD@YOUR-RDS-ENDPOINT:5432/DBNAME
# Find the endpoint in the RDS console -> your instance -> Connectivity & security.
# If your app and RDS are in the same VPC (e.g. same Beanstalk environment),
# you generally don't need sslmode=require; add "?sslmode=require" to the
# end of the URL if your RDS instance enforces SSL.
DATABASE_URL=postgresql://USERNAME:PASSWORD@your-db-instance.xxxxxxxxxx.us-east-1.rds.amazonaws.com:5432/exposureiq

# If your tables live under a non-default Postgres schema (check DBeaver's
# Database Navigator - if your tables are nested under Schemas > something
# other than "public", that's your schema name), set it here. Leave unset
# or "public" if your tables are directly under the default public schema.
DB_SCHEMA=public

# ---- AWS Bedrock (optional - only needed for the AI assistant widget) ----
AWS_REGION=us-east-1
BEDROCK_CHAT_MODEL_ID=anthropic.claude-3-5-sonnet-20241022-v2:0
BEDROCK_EMBED_MODEL_ID=amazon.titan-embed-text-v2:0

# Only needed for LOCAL runs. On Elastic Beanstalk, give the EB instance's
# IAM role bedrock:InvokeModel permission instead - don't put access keys
# in environment properties for anything deployed.
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
